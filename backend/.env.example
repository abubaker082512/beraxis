# ============================================================
# Beraxis AI Calling Platform — Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# ─── Application ────────────────────────────────────────────
APP_NAME=Beraxis
APP_ENV=production           # development | staging | production
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=info               # debug | info | warning | error

# ─── API Settings ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ─── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://beraxis_user:beraxis_pass@postgres:5432/beraxis_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CELERY_URL=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2
CACHE_TTL=3600               # seconds

# ─── Security & JWT ─────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_USE_256BIT_RANDOM_SECRET_HERE
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Encryption ─────────────────────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_32BYTE_FERNET_KEY_HERE

# ─── Admin ──────────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@beraxis.com
SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ─── Stripe Billing ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_STARTER_PRICE_ID=price_CHANGE_ME
STRIPE_PROFESSIONAL_PRICE_ID=price_CHANGE_ME
STRIPE_ENTERPRISE_PRICE_ID=price_CHANGE_ME

# ─── Telephony (Asterisk ARI) ───────────────────────────────
ASTERISK_HOST=asterisk         # Docker service name or IP
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=beraxis_ari
ASTERISK_ARI_PASS=CHANGE_ME
ASTERISK_ARI_APP=beraxis_app
SIP_TRUNK_HOST=sip.yourprovider.com
SIP_TRUNK_USER=CHANGE_ME
SIP_TRUNK_PASS=CHANGE_ME
OUTBOUND_CALLER_ID=+1XXXXXXXXXX
MAX_CONCURRENT_CALLS=100

# ─── AI — STT (Faster-Whisper) ──────────────────────────────
WHISPER_MODEL_SIZE=medium      # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cuda            # cpu | cuda
WHISPER_COMPUTE_TYPE=float16   # float32 | float16 | int8
WHISPER_MODEL_PATH=/models/whisper
WHISPER_LANGUAGE=en

# ─── AI — LLM (Llama 3 8B via llama.cpp) ───────────────────
LLAMA_MODEL_PATH=/models/llama/llama-3-8b-instruct.Q5_K_M.gguf
LLAMA_N_GPU_LAYERS=35          # -1 for full GPU offload
LLAMA_N_CTX=4096               # context window
LLAMA_MAX_TOKENS=512
LLAMA_TEMPERATURE=0.7
LLAMA_N_THREADS=8

# ─── AI — TTS (Piper) ───────────────────────────────────────
PIPER_MODELS_DIR=/models/piper
PIPER_DEFAULT_VOICE=en_US-amy-medium
PIPER_SAMPLE_RATE=22050

# ─── Storage ────────────────────────────────────────────────
STORAGE_BACKEND=local          # local | s3
STORAGE_LOCAL_PATH=/recordings
# If using S3:
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_BUCKET_NAME=beraxis-recordings
AWS_REGION=us-east-1

# ─── Email ──────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME
EMAIL_FROM=noreply@beraxis.com
EMAIL_FROM_NAME=Beraxis

# ─── Monitoring ─────────────────────────────────────────────
SENTRY_DSN=https://CHANGE_ME@sentry.io/PROJECT_ID
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASS=CHANGE_ME

# ─── OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
OAUTH_CALLBACK_URL=https://yourdomain.com/api/v1/auth/oauth/callback
